APP_NAME=MyApp
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=UTC

# JWT — genera una clave segura: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=your-256-bit-secret-here-change-me
JWT_TTL=86400
JWT_ALGO=HS256

# En Docker Compose (MySQL servicio moduxdb): DB_HOST=moduxdb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=my_database
DB_USER=root
DB_PASS=secret

MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME=MyApp

# CORS: separar con comas para múltiples orígenes
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=false

LOG_CHANNEL=file
LOG_LEVEL=debug

DISPLAY_ERRORS=true

# IA — driver: local | cloud | cluster
AI_DRIVER=cloud
AI_CLOUD_PROVIDER=openai
AI_CLOUD_API_KEY=
AI_CLOUD_MODEL=gpt-4o-mini
AI_CLOUD_EMBEDDING_MODEL=text-embedding-3-small

# IA local (llama.cpp)
LLAMA_SERVER_URL=http://127.0.0.1:8080
LLAMA_EMBED_URL=http://127.0.0.1:8081
LLAMA_MODEL=llama3
LLAMA_TIMEOUT=120

# RAG — store: sqlite | qdrant
RAG_STORE=sqlite
RAG_SQLITE_PATH=storage/ai/vectors.db
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=4
QDRANT_URL=http://127.0.0.1:6333
