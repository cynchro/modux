APP_NAME=MyApp
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=UTC

# JWT — genera una clave segura: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=your-256-bit-secret-here-change-me
JWT_TTL=86400
JWT_ALGO=HS256

# En Docker Compose (MySQL servicio moduxdb): DB_HOST=moduxdb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=my_database
DB_USER=root
DB_PASS=secret
# Conexiones PDO persistentes (mejor latencia; ajustá max_connections antes de activar).
DB_PERSISTENT=false

MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME=MyApp

# CORS: separar con comas para múltiples orígenes
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=false

LOG_CHANNEL=file
LOG_LEVEL=debug

DISPLAY_ERRORS=true

# IA (opcional) — add-on vía `composer require cynchro/modux-ia`.
# Las variables AI_*/LLAMA_*/RAG_* solo se necesitan si instalas el módulo IA.
# Ver la sección "Optional: AI module" en el README.

# Billing (opcional) — add-on vía `composer require cynchro/modux-billing cynchro/modux-billing-stripe`.
# Solo si instalas el módulo de billing (app/Modules/Billing):
#   BILLING_GATEWAY=stripe
#   STRIPE_API_KEY=        STRIPE_WEBHOOK_SECRET=   STRIPE_SUCCESS_URL=   STRIPE_CANCEL_URL=
#   MP_ACCESS_TOKEN=       MP_WEBHOOK_SECRET=       MP_BACK_URL=
# Ver la sección "Optional: Billing module" en el README.
