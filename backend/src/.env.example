APP_NAME=MyApp
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=UTC

# JWT — genera una clave segura: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=your-256-bit-secret-here-change-me
JWT_TTL=86400
JWT_ALGO=HS256

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=my_database
DB_USER=root
DB_PASS=secret

MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME=MyApp

# CORS: separar con comas para múltiples orígenes
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=false

LOG_CHANNEL=file
LOG_LEVEL=debug

DISPLAY_ERRORS=true
