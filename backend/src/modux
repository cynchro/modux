function tpl_routes(string $name): string
{
    $lower = strtolower($name) . 's';
    return <<<PHP
    <?php

    use App\Modules\\{$name}\Controllers\\{$name}Controller;
    use App\Http\Middleware\AuthMiddleware;

    \$router->group([AuthMiddleware::class], function (\$router) {
        \$router->get('/{$lower}',         [{$name}Controller::class, 'index']);
        \$router->get('/{$lower}/{id}',    [{$name}Controller::class, 'show']);
        \$router->post('/{$lower}',        [{$name}Controller::class, 'create']);
        \$router->put('/{$lower}/{id}',    [{$name}Controller::class, 'update']);
        \$router->delete('/{$lower}/{id}', [{$name}Controller::class, 'delete']);
    });
    PHP;
}
