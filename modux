    echo '    make:test <Name>                              Generate a unit test stub' . PHP_EOL;
    echo '    migrate                                       Run pending migrations' . PHP_EOL;
    echo '    migrate:rollback                              Roll back the last migration batch' . PHP_EOL;
    echo '    migrate:fresh                                 Roll back all and re-run' . PHP_EOL;
    echo '    routes                                        List all registered routes' . PHP_EOL;
    echo '    queue:work [--queue=default] [--sleep=3]      Process jobs from a queue' . PHP_EOL;
    echo '               [--once] [--timeout=10]' . PHP_EOL;
