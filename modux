function tpl_test(string $name): string
{
    return <<<PHP
    <?php

    namespace Tests\Unit\Modules\\{$name};

    use App\Modules\\{$name}\Services\\{$name}Service;
    use App\Modules\\{$name}\Repositories\\{$name}Repository;
    use App\Exceptions\NotFoundException;
    use Tests\Unit\UnitTestCase;

    class {$name}ServiceTest extends UnitTestCase
    {
        private {$name}Service    \$service;
        private {$name}Repository \$repository;

        protected function setUp(): void
        {
            \$this->repository = \$this->createMock({$name}Repository::class);
            \$this->service    = new {$name}Service(\$this->repository);
        }

        public function test_get_all_returns_list(): void
        {
            \$this->repository
                ->method('findAll')
                ->willReturn([['id' => 1], ['id' => 2]]);

            \$result = \$this->service->getAll();

            \$this->assertCount(2, \$result);
        }

        public function test_get_throws_not_found_for_missing_id(): void
        {
            \$this->repository
                ->method('findById')
                ->willThrowException(new NotFoundException('{$name}', 99));

            \$this->expectException(NotFoundException::class);
            \$this->service->get(99);
        }

        public function test_delete_returns_true_on_success(): void
        {
            \$this->repository
                ->method('delete')
                ->willReturn(true);

            \$this->assertTrue(\$this->service->delete(1));
        }
    }
    PHP;
}

function tpl_migration(string $slug): string
{
    $label = ucwords(str_replace('_', ' ', $slug));
    return <<<PHP
    <?php

    // Migration: {$label}

    return new class {
        public function up(\PDO \$pdo): void
        {
            \$pdo->exec("
                CREATE TABLE IF NOT EXISTS {$slug} (
                    id         INT       NOT NULL AUTO_INCREMENT PRIMARY KEY,
                    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
                ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci
            ");
        }

        public function down(\PDO \$pdo): void
        {
            \$pdo->exec('DROP TABLE IF EXISTS {$slug}');
        }
    };
    PHP;
}

function tpl_controller(string $name): string
{
    return <<<PHP
    <?php

    namespace App\Modules\\{$name}\Controllers;

    use App\Support\Request;
    use App\Support\Response;
    use App\Modules\\{$name}\Services\\{$name}Service;
    use App\Modules\\{$name}\Requests\Create{$name}Request;
    use App\Modules\\{$name}\Requests\Update{$name}Request;

    class {$name}Controller
    {
        public function __construct(private {$name}Service \$service)
        {
        }

        public function index(Request \$request): Response
        {
            return Response::success(\$this->service->getAll());
        }

        public function show(Request \$request): Response
        {
            \$id = (int) \$request->route('id');
            return Response::success(\$this->service->get(\$id));
        }

        public function create(Create{$name}Request \$request): Response
        {
            \$result = \$this->service->create(\$request->validated());
            return Response::success(\$result, 201);
        }

        public function update(Update{$name}Request \$request): Response
        {
            // route params are merged into FormRequest data by the router
            \$id     = (int) \$request->input('id');
            \$result = \$this->service->update(\$id, \$request->validated());
            return Response::success(['updated' => \$result]);
        }

        public function delete(Request \$request): Response
        {
            \$id = (int) \$request->route('id');
            \$this->service->delete(\$id);
            return Response::success(['message' => '{$name} deleted.']);
        }
    }
    PHP;
}

