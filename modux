#!/usr/bin/env php
<?php

/**
 * Modux — CLI
 *
 * Usage:
 *   php modux <command> [argument] [--flags]
 */

define('BASE_PATH', __DIR__);

$command = $argv[1] ?? null;
$arg     = null;
$flags   = [];

foreach (array_slice($argv, 2) as $a) {
    if (str_starts_with($a, '--')) {
        $flags[] = $a;
    } elseif ($arg === null) {
        $arg = $a;
    }
}

match ($command) {
    'make:module'      => makeModule($arg, $flags),
    'make:migration'   => makeMigration($arg),
    'make:test'        => makeTest($arg),
    'migrate'          => runMigrations(),
    'migrate:rollback' => rollbackMigration(),
    'migrate:fresh'    => freshMigrations(),
    'routes'           => showRoutes(),
    'queue:work'       => queueWork($flags),
    'queue:failed'     => queueFailed(),
    'queue:retry'      => queueRetry($arg),
    'queue:flush'      => queueFlush(),
    'entitlements:roll-periods' => rollEntitlementPeriods(),
    default            => help(),
};

// ─────────────────────────────────────────────────────────────────────────────

function makeModule(?string $name, array $flags = []): void
{
    if (!$name) {
        error('Usage: php modux make:module <Name> [--with-tenant]');
    }

    $name       = ucfirst($name);
    $withTenant = in_array('--with-tenant', $flags, true);
    $base       = BASE_PATH . "/app/Modules/{$name}";

    if (is_dir($base)) {
        error("Module [{$name}] already exists at app/Modules/{$name}/");
    }

    foreach ([$base, "{$base}/Controllers", "{$base}/Repositories", "{$base}/Requests", "{$base}/Services"] as $dir) {
        mkdir($dir, 0755, true);
    }

    $files = [
        "{$base}/Controllers/{$name}Controller.php"   => tpl_controller($name),
        "{$base}/Repositories/{$name}Repository.php"  => $withTenant
            ? tpl_repository_tenant($name)
            : tpl_repository($name),
        "{$base}/Services/{$name}Service.php"         => tpl_service($name),
        "{$base}/Requests/Create{$name}Request.php"   => tpl_request($name, 'Create'),
        "{$base}/Requests/Update{$name}Request.php"   => tpl_request($name, 'Update'),
        "{$base}/routes.php"                          => $withTenant
            ? tpl_routes_tenant($name)
            : tpl_routes($name),
    ];

    foreach ($files as $path => $content) {
        file_put_contents($path, $content);
        line('  <green>created</green>  ' . str_replace(BASE_PATH . '/', '', $path));
    }

    echo PHP_EOL;
    line('<yellow>Next steps:</yellow>');
    line('  1. Add your columns to the repository create() and update() methods.');
    line('  2. Add validation rules to Create/Update requests.');
    line('  3. Run: php modux make:migration create_' . strtolower($name) . 's_table');
    if ($withTenant) {
        line('  4. Add tenant_id column to your migration table.');
    }
    echo PHP_EOL;
}

function makeTest(?string $name): void
{
    if (!$name) {
        error('Usage: php modux make:test <ModuleName>');
    }

    $name = ucfirst($name);
    $dir  = BASE_PATH . "/tests/Unit/Modules/{$name}";

    if (!is_dir($dir)) {
        mkdir($dir, 0755, true);
    }

    $path = "{$dir}/{$name}ServiceTest.php";

    if (file_exists($path)) {
        error("Test [{$name}ServiceTest] already exists.");
    }

    file_put_contents($path, tpl_test($name));
    line('  <green>created</green>  ' . str_replace(BASE_PATH . '/', '', $path));
    echo PHP_EOL;
}

function makeMigration(?string $name): void
{
    if (!$name) {
        error('Usage: php modux make:migration <name>');
    }

    $slug      = strtolower(preg_replace('/\s+/', '_', trim($name)));
    $files     = glob(BASE_PATH . '/migrations/[0-9]*.php') ?: [];
    $next      = str_pad((string) (count($files) + 1), 4, '0', STR_PAD_LEFT);
    $filename  = "{$next}_{$slug}.php";
    $path      = BASE_PATH . "/migrations/{$filename}";

    file_put_contents($path, tpl_migration($slug));
    line('  <green>created</green>  migrations/' . $filename);
    echo PHP_EOL;
}

function runMigrations(): void
{
    $pdo = buildPdo();

    $pdo->exec("
        CREATE TABLE IF NOT EXISTS migrations (
            id        INT          NOT NULL AUTO_INCREMENT PRIMARY KEY,
            migration VARCHAR(255) NOT NULL UNIQUE,
            batch     INT          NOT NULL DEFAULT 1,
            ran_at    TIMESTAMP    DEFAULT CURRENT_TIMESTAMP
        ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4
    ");

    // Add batch column to existing installations that pre-date this feature
    try {
        $pdo->exec('ALTER TABLE migrations ADD COLUMN batch INT NOT NULL DEFAULT 1');
    } catch (\PDOException) {
        // Column already exists — safe to ignore
    }

    $ran   = $pdo->query('SELECT migration FROM migrations')->fetchAll(\PDO::FETCH_COLUMN);
    $files = glob(BASE_PATH . '/migrations/[0-9]*.php') ?: [];
    sort($files);

    $batchRow = $pdo->query('SELECT MAX(batch) FROM migrations')->fetchColumn();
    $batch    = ($batchRow === null || $batchRow === false) ? 1 : (int) $batchRow + 1;

    $count = 0;
    foreach ($files as $file) {
        $filename = basename($file);

        if (in_array($filename, $ran, true)) {
            line("  <gray>skipped</gray>   {$filename}");
            continue;
        }

        $migration = require $file;
        $migration->up($pdo);

        $pdo->prepare('INSERT INTO migrations (migration, batch) VALUES (?, ?)')
            ->execute([$filename, $batch]);
        line("  <green>migrated</green>  {$filename}");
        $count++;
    }

    echo PHP_EOL;
    line($count > 0 ? "<green>{$count} migration(s) ran.</green>" : 'Nothing to migrate.');
    echo PHP_EOL;
}

function rollbackMigration(): void
{
    $pdo = buildPdo();

    $row = $pdo->query(
        'SELECT migration, batch FROM migrations ORDER BY id DESC LIMIT 1'
    )->fetch(\PDO::FETCH_ASSOC);

    if (!$row) {
        line('Nothing to roll back.');
        echo PHP_EOL;
        return;
    }

    $batch = (int) $row['batch'];
    $inBatch = $pdo->prepare('SELECT migration FROM migrations WHERE batch = ? ORDER BY id DESC');
    $inBatch->execute([$batch]);
    $toRollback = $inBatch->fetchAll(\PDO::FETCH_COLUMN);

    foreach ($toRollback as $filename) {
        $file = BASE_PATH . '/migrations/' . $filename;

        if (!file_exists($file)) {
            line("  <gray>missing</gray>   {$filename} (file not found — skipped)");
            continue;
        }

        $migration = require $file;
        $migration->down($pdo);

        $pdo->prepare('DELETE FROM migrations WHERE migration = ?')->execute([$filename]);
        line("  <green>rolled back</green>  {$filename}");
    }

    echo PHP_EOL;
    line('<green>Batch ' . $batch . ' rolled back.</green>');
    echo PHP_EOL;
}

function freshMigrations(): void
{
    $pdo   = buildPdo();
    $files = glob(BASE_PATH . '/migrations/[0-9]*.php') ?: [];
    sort($files);
    $reversed = array_reverse($files);

    line('<yellow>Rolling back all migrations...</yellow>');
    echo PHP_EOL;

    foreach ($reversed as $file) {
        $filename  = basename($file);
        $migration = require $file;
        $migration->down($pdo);
        line("  <green>rolled back</green>  {$filename}");
    }

    try {
        $pdo->exec('DROP TABLE IF EXISTS migrations');
    } catch (\PDOException) {
    }

    echo PHP_EOL;
    line('<yellow>Re-running all migrations...</yellow>');
    echo PHP_EOL;

    runMigrations();
}

// ── Queue commands ────────────────────────────────────────────────────────────

function queueWork(array $flags): void
{
    $queue  = flagValue($flags, '--queue', 'default');
    $sleep  = (int) flagValue($flags, '--sleep', '3');
    $once   = in_array('--once', $flags, true);
    $timeout = (int) flagValue($flags, '--timeout', '10');

    $app        = buildApp();
    $pdo        = $app->get(\PDO::class);
    $dispatcher = $app->get(\App\Support\JobDispatcher::class);

    // Release jobs stuck in "running" from previous crashed workers
    $stuck = $dispatcher->releaseStuck($timeout);
    if ($stuck > 0) {
        line("<yellow>Released {$stuck} stuck job(s).</yellow>");
    }

    line("Worker started on queue <yellow>[{$queue}]</yellow>.");
    echo PHP_EOL;

    // Graceful shutdown on SIGINT / SIGTERM
    $running = true;
    if (function_exists('pcntl_signal')) {
        pcntl_signal(SIGINT,  function () use (&$running) { $running = false; });
        pcntl_signal(SIGTERM, function () use (&$running) { $running = false; });
    }

    do {
        if (function_exists('pcntl_signal_dispatch')) {
            pcntl_signal_dispatch();
        }

        $jobRow = $dispatcher->claim($queue);

        if ($jobRow === null) {
            if ($once) {
                break;
            }
            sleep($sleep);
            continue;
        }

        $payload = json_decode((string) $jobRow['payload'], true);
        $class   = $payload['class'] ?? '';
        $data    = $payload['data']  ?? [];

        if (!class_exists($class)) {
            $dispatcher->fail($jobRow, new \RuntimeException("Job class [{$class}] not found."));
            line("  <gray>failed</gray>  #{$jobRow['id']} class not found: {$class}");
            if ($once) break;
            continue;
        }

        $start = microtime(true);
        line("  <yellow>running</yellow>  #{$jobRow['id']} {$class}");

        try {
            /** @var \App\Support\Job $job */
            $job = $app->get($class);

            foreach ($data as $prop => $value) {
                $job->$prop = $value;
            }

            $job->handle($app);
            $dispatcher->complete((int) $jobRow['id']);

            $ms = round((microtime(true) - $start) * 1000);
            line("  <green>done</green>     #{$jobRow['id']} {$class} [{$ms}ms]");
        } catch (\Throwable $e) {
            $dispatcher->fail($jobRow, $e);
            $ms      = round((microtime(true) - $start) * 1000);
            $attempt = (int) $jobRow['attempts'];
            $max     = (int) $jobRow['max_attempts'];
            line("  <gray>failed</gray>   #{$jobRow['id']} {$class} [{$ms}ms] attempt {$attempt}/{$max}: {$e->getMessage()}");
        }

    } while (!$once && $running);

    echo PHP_EOL;
    line('Worker stopped.');
    echo PHP_EOL;
}

function queueFailed(): void
{
    $app        = buildApp();
    $dispatcher = $app->get(\App\Support\JobDispatcher::class);
    $jobs       = $dispatcher->failedJobs(50);

    if (empty($jobs)) {
        line('No failed jobs.');
        echo PHP_EOL;
        return;
    }

    echo PHP_EOL;
    printf("  %-6s %-12s %-40s %-20s %s\n", 'ID', 'QUEUE', 'CLASS', 'FAILED AT', 'ATTEMPTS');
    echo '  ' . str_repeat('─', 100) . PHP_EOL;

    foreach ($jobs as $job) {
        $payload = json_decode((string) $job['payload'], true);
        $class   = class_basename($payload['class'] ?? '?');
        printf(
            "  \033[31m%-6s\033[0m %-12s \033[33m%-40s\033[0m %-20s %s\n",
            $job['id'],
            $job['queue'],
            $class,
            $job['failed_at'],
            $job['attempts']
        );
    }

    echo PHP_EOL;
    line('Run <yellow>php modux queue:retry <id></yellow> to retry a job.');
    echo PHP_EOL;
}

function queueRetry(?string $id): void
{
    if (!$id || !ctype_digit($id)) {
        error('Usage: php modux queue:retry <job-id>');
    }

    $app        = buildApp();
    $dispatcher = $app->get(\App\Support\JobDispatcher::class);
    $success    = $dispatcher->retry((int) $id);

    if ($success) {
        line("<green>Job #{$id} queued for retry.</green>");
    } else {
        line("<gray>Job #{$id} not found or is not in failed status.</gray>");
    }
    echo PHP_EOL;
}

function queueFlush(): void
{
    $pdo = buildPdo();
    $stmt = $pdo->prepare('DELETE FROM jobs WHERE status = "failed"');
    $stmt->execute();
    $count = $stmt->rowCount();
    line("<green>Deleted {$count} failed job(s).</green>");
    echo PHP_EOL;
}

// ── Entitlements ──────────────────────────────────────────────────────────────

/**
 * Red de seguridad: avanza los ciclos de quota vencidos (period_end < now) por
 * su propia duración hasta cubrir el presente. En operación normal billing
 * mantiene period_start/period_end vía webhooks; este comando es idempotente y
 * cubre los huecos. Mover la ventana "resetea" la cuota sin borrar usage_events.
 */
function rollEntitlementPeriods(): void
{
    $pdo = buildPdo();
    $now = time();

    $rows = $pdo->query(
        "SELECT id, period_start, period_end FROM tenant_entitlements
         WHERE type = 'quota' AND period_start IS NOT NULL AND period_end IS NOT NULL
           AND period_end < NOW()"
    )->fetchAll(\PDO::FETCH_ASSOC);

    $update = $pdo->prepare(
        'UPDATE tenant_entitlements SET period_start = ?, period_end = ? WHERE id = ?'
    );

    $rolled = 0;
    foreach ($rows as $row) {
        $start = strtotime((string) $row['period_start']);
        $end   = strtotime((string) $row['period_end']);
        $span  = $end - $start;

        if ($span <= 0) {
            continue; // datos inconsistentes — no tocar
        }

        while ($end < $now) {
            $start = $end;
            $end  += $span;
        }

        $update->execute([
            date('Y-m-d H:i:s', $start),
            date('Y-m-d H:i:s', $end),
            $row['id'],
        ]);
        $rolled++;
    }

    line("<green>Rolled {$rolled} entitlement period(s).</green>");
    echo PHP_EOL;
}

function showRoutes(): void
{
    require_once BASE_PATH . '/vendor/autoload.php';

    $dotenv = Dotenv\Dotenv::createImmutable(BASE_PATH);
    $dotenv->safeLoad();

    App\Support\Config::setPath(BASE_PATH . '/config');

    $container = new App\Support\Container();
    $router    = new App\Support\Router($container);
    $container->instance(App\Support\Router::class, $router);

    foreach (glob(BASE_PATH . '/app/Modules/*/routes.php') as $file) {
        require $file;
    }

    $routes = $router->getRegisteredRoutes();

    if (empty($routes)) {
        line('No routes registered.');
        return;
    }

    $mw = 18;
    $uw = 38;
    $hw = 40;

    echo PHP_EOL;
    printf("  %-{$mw}s %-{$uw}s %-{$hw}s %s\n", 'METHOD', 'URI', 'HANDLER', 'MIDDLEWARES');
    echo '  ' . str_repeat('─', $mw + $uw + $hw + 30) . PHP_EOL;

    foreach ($routes as $route) {
        [$controller, $method] = $route['action'];
        $handler     = class_basename($controller) . '@' . $method;
        $middlewares = implode(', ', array_map('class_basename', $route['middlewares']));

        printf(
            "  \033[33m%-{$mw}s\033[0m %-{$uw}s \033[32m%-{$hw}s\033[0m %s\n",
            $route['method'],
            $route['uri'],
            $handler,
            $middlewares
        );
    }

    echo PHP_EOL;
}

// ── Helpers ───────────────────────────────────────────────────────────────────

function buildApp(): \App\Support\Container
{
    return require BASE_PATH . '/bootstrap/app.php';
}

function flagValue(array $flags, string $flag, string $default): string
{
    foreach ($flags as $f) {
        if (str_starts_with($f, $flag . '=')) {
            return substr($f, strlen($flag) + 1);
        }
    }
    return $default;
}

function buildPdo(): \PDO
{
    require_once BASE_PATH . '/vendor/autoload.php';

    $dotenv = Dotenv\Dotenv::createImmutable(BASE_PATH);
    $dotenv->safeLoad();
    $dotenv->required(['DB_HOST', 'DB_NAME', 'DB_USER', 'DB_PASS']);

    return new \PDO(
        sprintf('mysql:host=%s;port=%s;dbname=%s;charset=utf8mb4',
            $_ENV['DB_HOST'], $_ENV['DB_PORT'] ?? 3306, $_ENV['DB_NAME']),
        $_ENV['DB_USER'],
        $_ENV['DB_PASS'],
        [\PDO::ATTR_ERRMODE => \PDO::ERRMODE_EXCEPTION]
    );
}

function class_basename(string $class): string
{
    return basename(str_replace('\\', '/', $class));
}

