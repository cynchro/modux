{
    "name": "cynchro/modux",
    "description": "A lightweight, dependency-injection-first PHP framework organized as a modular monolith.",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Modux",
            "homepage": "https://github.com/cynchro/modux"
        }
    ],
    "repositories": [
        { "type": "vcs", "url": "https://github.com/cynchro/modux-billing.git" },
        { "type": "vcs", "url": "https://github.com/cynchro/modux-billing-stripe.git" },
        { "type": "vcs", "url": "https://github.com/cynchro/modux-billing-mp.git" }
    ],
    "require": {
        "php": "^8.2",
        "firebase/php-jwt": "^6.10",
        "phpmailer/phpmailer": "^6.9",
        "psr/container": "^2.0",
        "psr/log": "^3.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "squizlabs/php_codesniffer": "^3.9",
        "phpstan/phpstan": "^2.0",
        "cynchro/modux-billing": ">=0.0.1 <1.0",
        "cynchro/modux-billing-stripe": ">=0.0.1 <1.0",
        "cynchro/modux-billing-mp": ">=0.0.1 <1.0"
    },
    "suggest": {
        "cynchro/modux-ia": "SDK opcional de IA (LLM + RAG). Instálalo con `composer require cynchro/modux-ia` y añade el módulo app/Modules/IA para habilitar los endpoints /ia/*.",
        "cynchro/modux-billing": "Capa de billing (planes, suscripciones, entitlements). Activa el módulo app/Modules/Billing (endpoints /billing/*).",
        "cynchro/modux-billing-stripe": "Adaptador de pasarela Stripe para el módulo de billing.",
        "cynchro/modux-billing-mp": "Adaptador de pasarela Mercado Pago (AR) para el módulo de billing."
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/phpcs",
        "fix": "vendor/bin/phpcbf",
        "analyse": "vendor/bin/phpstan analyse --no-progress"
    },
    "bin": [
        "modux"
    ],
    "config": {
        "sort-packages": true
    }
}
