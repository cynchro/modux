{
    "name": "cynchro/modux",
    "description": "A lightweight, dependency-injection-first PHP framework organized as a modular monolith.",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Modux",
            "homepage": "https://github.com/cynchro/modux"
        }
    ],
    "repositories": [
        {
            "type": "path",
            "url": "../../modulos/ia",
            "options": {"symlink": true}
        }
    ],
    "require": {
        "php": "^8.2",
        "firebase/php-jwt": "^6.10",
        "cynchro/modux-ia": "@dev",
        "phpmailer/phpmailer": "^6.9",
        "psr/container": "^2.0",
        "psr/log": "^3.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "squizlabs/php_codesniffer": "^3.9",
        "phpstan/phpstan": "^1.11"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/phpcs",
        "fix": "vendor/bin/phpcbf",
        "analyse": "vendor/bin/phpstan analyse --no-progress"
    },
    "bin": [
        "modux"
    ],
    "config": {
        "sort-packages": true
    }
}
