<?xml version="1.0"?>
<ruleset name="Modux">
    <arg name="basepath" value="."/>
    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <rule ref="PSR12"/>

    <file>app/</file>
    <file>bootstrap/</file>
    <file>config/</file>
    <file>tests/</file>

    <exclude-pattern>app/Modules/*/Views/*</exclude-pattern>
    <exclude-pattern>vendor/*</exclude-pattern>
</ruleset>
